# ── Configuration JetWatch Africa ──────────────────────────────────────────────

# Clés API pour l'Intelligence IA (CrewAI & Cohere)
# Recommandé : Groq (Llama 3.1 70B) — Gratuit et extrêmement rapide
GROQ_API_KEY=your_groq_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# Moteur de recherche pour les agents OSINT
# Recommandé : Serper.dev (2500 requêtes gratuites/mois)
SERPER_API_KEY=your_serper_api_key_here

# Optionnel : Autres LLMs
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Configuration de la base de données (SQLite par défaut)
DATABASE_URL=sqlite:///./jetwatch.db

# Configuration Twitter/X (pour le bot social)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Sécurité (EC-PoW & ECDH)
# Laissez vide pour génération automatique au démarrage
ECC_PRIVATE_KEY_PEM=

# Environnement (development / production)
ENV=development
PORT=8000
