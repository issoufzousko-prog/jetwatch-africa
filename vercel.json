{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/pow/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/ecdh/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/proxy-image",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/poll",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/clean",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-post",
      "schedule": "0 18 * * *"
    }
  ]
}
